@inject LibraryStateService LibraryState
@implements IDisposable

<button class="@ButtonClass" type="button" @onclick="Toggle" @onclick:stopPropagation="true" aria-label="Toggle favorite">
    @if (LibraryState.IsFavorite(Track))
    {
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-4 w-4 fill-current"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5C2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3C19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35Z" /></svg>
    }
    else
    {
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-4 w-4 fill-current"><path d="m12.1 18.55-.1.1-.11-.1C7.14 14.24 4 11.39 4 8.5C4 6.5 5.5 5 7.5 5c1.54 0 3.04.99 3.57 2.36h1.87C13.46 5.99 14.96 5 16.5 5C18.5 5 20 6.5 20 8.5c0 2.89-3.14 5.74-7.9 10.05M16.5 3c-1.74 0-3.41.81-4.5 2.09C10.91 3.81 9.24 3 7.5 3C4.42 3 2 5.42 2 8.5c0 3.78 3.4 6.86 8.55 11.54L12 21.35l1.45-1.32C18.6 15.36 22 12.28 22 8.5C22 5.42 19.58 3 16.5 3" /></svg>
    }
</button>

@code {
    [Parameter, EditorRequired] public MusicInfoModel Track { get; set; } = default!;
    [Parameter] public string Class { get; set; } = string.Empty;

    private string ButtonClass => string.IsNullOrWhiteSpace(Class)
        ? "inline-flex h-9 w-9 items-center justify-center rounded-full border border-theme bg-panel text-accent transition hover:bg-accent-soft"
        : Class;

    protected override void OnInitialized()
    {
        LibraryState.Changed += OnLibraryChanged;
    }

    private async Task Toggle()
    {
        await LibraryState.ToggleFavoriteAsync(Track);
    }

    private void OnLibraryChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        LibraryState.Changed -= OnLibraryChanged;
    }
}
