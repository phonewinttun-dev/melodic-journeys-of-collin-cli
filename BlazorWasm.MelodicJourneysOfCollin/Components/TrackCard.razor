@inject PlayerStateService PlayerState

<div class="group flex items-center gap-4 rounded-[1.5rem] border-2 border-black bg-[var(--bg-elevated)] p-4 shadow-[4px_4px_0_0_rgba(0,0,0,0.9)] transition hover:translate-x-[1px] hover:translate-y-[1px] hover:shadow-none dark:border-white">
    <div class="relative h-16 w-16 shrink-0 overflow-hidden rounded-[1rem] border-2 border-black dark:border-white">
        <img src="@Track.Cover" alt="@Track.Name" class="h-full w-full object-cover" />
    </div>

    <div class="min-w-0 flex-1">
        <div class="flex items-center gap-2 text-[0.68rem] font-semibold uppercase tracking-[0.3em] text-muted">
            <span>@Track.Genre</span>
            <span class="h-1 w-1 rounded-full bg-[var(--accent)]"></span>
            <span>@Track.Length</span>
        </div>
        <h3 class="mt-2 truncate font-display text-3xl text-[var(--fg)]">@DisplayName</h3>
        <p class="truncate text-sm text-muted">@Track.Artists</p>
        @if (!string.IsNullOrWhiteSpace(Track.AlbumTitle))
        {
            <p class="truncate text-xs uppercase tracking-[0.25em] text-accent">@Track.AlbumTitle</p>
        }
    </div>

    <div class="flex items-center gap-2">
        <FavoriteButton Track="Track" />
        <button class="inline-flex h-10 w-10 items-center justify-center rounded-full border-2 border-black bg-[var(--accent)] text-white transition hover:translate-x-[1px] hover:translate-y-[1px] hover:shadow-none shadow-[3px_3px_0_0_rgba(0,0,0,0.9)] dark:border-white" type="button" @onclick="PlayTrack">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-5 w-5 fill-current"><path d="M8 5v14l11-7z"/></svg>
        </button>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public MusicInfoModel Track { get; set; } = default!;

    private string DisplayName => (Track.Name ?? string.Empty).Replace(".mp3", string.Empty, StringComparison.OrdinalIgnoreCase);

    private void PlayTrack() => PlayerState.PlayTrack(Track);
}
