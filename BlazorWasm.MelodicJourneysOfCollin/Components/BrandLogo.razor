<div class="@ClassName" style="width: @(Size)px; height: @(Size)px;">
    <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full">
        <!-- Deck Base with retro border -->
        <rect x="2" y="4" width="28" height="24" rx="3" fill="var(--accent)" stroke="currentColor" stroke-width="2" class="text-black dark:text-white"/>
        
        <!-- Turntable Platter/Vinyl -->
        <circle cx="14" cy="16" r="9" fill="black" stroke="#333" stroke-width="1"/>
        <circle cx="14" cy="16" r="6" fill="black" stroke="#444" stroke-width="0.5"/>
        <circle cx="14" cy="16" r="1.5" fill="var(--accent)"/>
        
        <!-- Tonearm base -->
        <circle cx="26" cy="10" r="2.5" fill="black" stroke="white" stroke-width="1"/>
        
        <!-- Tonearm -->
        <path d="M26 10L26 20L18 21" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        
        <!-- Pitch Slider -->
        <rect x="26" y="15" width="2" height="8" rx="1" fill="black" opacity="0.6"/>
        <rect x="25.5" y="18" width="3" height="2" fill="white"/>
        
        <!-- Power Light -->
        <circle cx="5" cy="24" r="1" fill="#00ff00"/>
    </svg>
</div>

@code {
    [Parameter] public int Size { get; set; } = 48;
    [Parameter] public string ClassName { get; set; } = "";
}
