@page "/albums"
@inject PlayerStateService PlayerState
@inject LibraryStateService LibraryState

<div class="space-y-8 md:space-y-10">
    <section class="surface-panel rounded-[2rem] p-6 md:p-8">
        <SectionHeader Eyebrow="Collections" Title="Albums" Description="Curated album groupings built on top of the local playlist, each with its own detail view and play-all action." />
    </section>

    <section class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
        @foreach (var album in LibraryState.Albums)
        {
            <article class="surface-panel rounded-[1.75rem] p-5">
                <img src="@album.Cover" alt="@album.Title" class="h-56 w-full rounded-[1.5rem] border-2 border-black object-cover dark:border-white" />
                <div class="mt-5 space-y-3">
                    <div class="text-xs uppercase tracking-[0.35em] text-accent">@album.Tracks.Count tracks</div>
                    <h2 class="font-display text-4xl text-[var(--fg)]">@album.Title</h2>
                    <p class="text-sm text-muted">@album.Artist</p>
                    <div class="flex items-center gap-3 pt-2">
                        <button class="inline-flex items-center justify-center rounded-full border-2 border-black bg-[var(--accent)] px-5 py-3 text-xs font-semibold uppercase tracking-[0.3em] text-white shadow-[4px_4px_0_0_rgba(0,0,0,0.9)] transition hover:translate-x-[1px] hover:translate-y-[1px] hover:shadow-none dark:border-white" type="button" @onclick="() => PlayerState.PlayQueue(album.Tracks)">Play All</button>
                        <a href="@($"/albums/{album.Id}")" class="inline-flex items-center justify-center rounded-full border-2 border-black bg-[var(--bg)] px-5 py-3 text-xs font-semibold uppercase tracking-[0.3em] text-[var(--fg)] transition hover:bg-accent-soft dark:border-white">Open</a>
                    </div>
                </div>
            </article>
        }
    </section>
</div>
