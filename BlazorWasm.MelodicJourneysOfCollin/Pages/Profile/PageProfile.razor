@page "/profile"

@{
    var timeline = new[]
    {
        new { Year = "2016", Title = "Kavin & Collin - Melody Of Angels", Detail = "One of the early signature melodic releases that helped define the project voice." },
        new { Year = "2017", Title = "Sage x Collin - Imaginations", Detail = "A collaboration phase that expanded the catalog's emotional and progressive range." },
        new { Year = "2018", Title = "Collin - Senses", Detail = "A strong solo marker and a good example of the euphoric melodic structure that keeps resurfacing in the catalog." },
        new { Year = "2019", Title = "Sagemode x Collin - HIT", Detail = "A sharper, club-facing stretch with more impact-focused arrangement choices." },
        new { Year = "2021-2023", Title = "Edits, remixes, and local day mixes", Detail = "The library grows into a blend of original productions, remixes, and long-form mixes built for sets." }
    };
}

<div class="space-y-8 md:space-y-10">
    <section class="grid gap-6 lg:grid-cols-[1.1fr_0.9fr]">
        <div class="surface-panel rope-border rounded-[2rem] p-6 md:p-8">
            <div class="flex flex-col gap-6 md:flex-row md:items-center">
                <img src="assets/img/profile.png" alt="Collin" class="h-36 w-36 rounded-[2rem] border border-theme object-cover shadow-2xl" />
                <div class="space-y-4">
                    <div class="section-label">Artist Profile</div>
                    <h1 class="headline-display text-6xl uppercase leading-none tracking-[0.1em] text-[var(--fg)] md:text-7xl">Collin</h1>
                    <p class="max-w-2xl text-base leading-8 text-muted">Music producer and DJ working across big room, progressive house, future house, and melodic festival edits with a catalog that mixes punchy live energy with emotional hooks.</p>
                    <div class="flex flex-wrap gap-3 text-xs uppercase tracking-[0.3em] text-muted">
                        <a href="https://www.facebook.com/burma.colllin" target="_blank" class="rounded-full border border-theme px-4 py-2 transition hover:bg-accent-soft">Facebook</a>
                        <a href="https://www.youtube.com/@@BurmaCollin" target="_blank" class="rounded-full border border-theme px-4 py-2 transition hover:bg-accent-soft">YouTube</a>
                        <a href="https://instagram.com/sannlynnhtun" target="_blank" class="rounded-full border border-theme px-4 py-2 transition hover:bg-accent-soft">Instagram</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="grid gap-6 sm:grid-cols-3 lg:grid-cols-1">
            <div class="surface-panel rope-border rounded-[2rem] p-5">
                <div class="text-xs uppercase tracking-[0.35em] text-muted">Catalog Size</div>
                <div class="mt-3 headline-display text-5xl uppercase text-[var(--fg)]">@MusicService.LocalPlaylist.Count</div>
            </div>
            <div class="surface-panel rope-border rounded-[2rem] p-5">
                <div class="text-xs uppercase tracking-[0.35em] text-muted">Signature Lane</div>
                <div class="mt-3 text-lg font-semibold text-[var(--fg)]">Festival EDM with melodic lift</div>
            </div>
            <div class="surface-panel rope-border rounded-[2rem] p-5">
                <div class="text-xs uppercase tracking-[0.35em] text-muted">Base</div>
                <div class="mt-3 text-lg font-semibold text-[var(--fg)]">Yangon, Myanmar</div>
            </div>
        </div>
    </section>

    <section class="grid gap-6 lg:grid-cols-[0.95fr_1.05fr]">
        <div class="surface-panel rope-border rounded-[2rem] p-6 md:p-8">
            <SectionHeader Eyebrow="Identity" Title="Built for release day and live energy" Description="Collin's work balances punch, melody, and a crowd-facing sense of momentum. The profile page leans into that with a more editorial layout than the old card template." />
            <div class="mt-6 space-y-4 text-sm leading-8 text-muted md:text-base">
                <p>From early self-released originals to remixes and long-form day mixes, the catalog shows a steady interest in tension-and-release structures, bright synth phrasing, and clean festival drops.</p>
                <p>The redesigned profile keeps the story direct: a quick scan tells you who the artist is, where the sound sits, and which releases form the spine of the project.</p>
            </div>
        </div>

        <div class="surface-panel rope-border rounded-[2rem] p-6 md:p-8">
            <SectionHeader Eyebrow="Milestones" Title="A compact release timeline" Description="A few anchor points from the catalog that illustrate how the sound evolved over time." />
            <div class="mt-8 space-y-4">
                @foreach (var item in timeline)
                {
                    <div class="grid gap-3 rounded-[1.5rem] border border-theme px-4 py-4 md:grid-cols-[110px_1fr] md:items-start">
                        <div class="headline-display text-3xl uppercase tracking-[0.12em] text-accent">@item.Year</div>
                        <div>
                            <div class="text-lg font-semibold text-[var(--fg)]">@item.Title</div>
                            <p class="mt-2 text-sm leading-7 text-muted">@item.Detail</p>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>
</div>


