@page "/releases"
@page "/releasesNew"
@inject PlayerStateService PlayerState
@inject LibraryStateService LibraryState

@{
    var tracks = FilteredTracks().ToList();
}

<div class="space-y-8 md:space-y-10">
    <section class="surface-panel rounded-[2rem] p-6 md:p-8">
        <SectionHeader Eyebrow="Discography" Title="Release crate" Description="Every local release is playable from here, and each one can be favorited or opened through its album grouping.">
            <Actions>
                <div class="rounded-full border-2 border-black px-4 py-2 text-xs font-semibold uppercase tracking-[0.35em] text-muted dark:border-white">@tracks.Count track@(tracks.Count == 1 ? string.Empty : "s")</div>
            </Actions>
        </SectionHeader>

        <div class="mt-8 grid gap-4 md:grid-cols-[1fr_auto]">
            <label class="flex items-center gap-3 rounded-full border-2 border-black bg-[var(--bg)] px-4 py-3 dark:border-white">
                <span class="text-xs uppercase tracking-[0.35em] text-muted">Search</span>
                <input class="w-full bg-transparent text-sm outline-none placeholder:text-muted" placeholder="Track, artist, or album" @bind="SearchTerm" @bind:event="oninput" />
            </label>
            <button class="rounded-full border-2 border-black px-5 py-3 text-xs font-semibold uppercase tracking-[0.35em] transition hover:bg-accent-soft dark:border-white" type="button" @onclick="ClearSearch">Clear</button>
        </div>
    </section>

    <section class="grid gap-4 xl:grid-cols-2">
        @foreach (var track in tracks)
        {
            <div class="surface-panel rounded-[1.75rem] p-5">
                <div class="flex flex-col gap-5 md:flex-row md:items-center">
                    <img src="@track.Cover" alt="@track.Name" class="h-24 w-24 rounded-[1.5rem] border-2 border-black object-cover dark:border-white" />
                    <div class="min-w-0 flex-1">
                        <div class="flex flex-wrap items-center gap-2 text-[0.68rem] font-semibold uppercase tracking-[0.35em] text-muted">
                            <span>@track.Genre</span>
                            <span class="h-1 w-1 rounded-full bg-[var(--accent)]"></span>
                            <span>@track.Length</span>
                            <span class="h-1 w-1 rounded-full bg-[var(--accent)]"></span>
                            <span>@track.AlbumTitle</span>
                        </div>
                        <h3 class="mt-3 font-display text-4xl text-[var(--fg)]">@DisplayName(track)</h3>
                        <p class="mt-2 text-sm text-muted">@track.Artists</p>
                        <p class="mt-3 text-sm leading-7 text-muted">Launch this track instantly, save it to favorites, or jump into its album collection without breaking playback.</p>
                    </div>
                    <div class="flex items-center gap-3">
                        <FavoriteButton Track="track" />
                        <button class="rounded-full border-2 border-black bg-[var(--accent)] px-5 py-3 text-xs font-semibold uppercase tracking-[0.35em] text-white shadow-[4px_4px_0_0_rgba(0,0,0,0.9)] transition hover:translate-x-[1px] hover:translate-y-[1px] hover:shadow-none dark:border-white" type="button" @onclick="() => PlayerState.PlayTrack(track)">Play</button>
                    </div>
                </div>
            </div>
        }
    </section>
</div>

@code {
    private string SearchTerm { get; set; } = string.Empty;

    private IEnumerable<MusicInfoModel> FilteredTracks()
    {
        var tracks = MusicService.LocalPlaylist.AsEnumerable();
        if (string.IsNullOrWhiteSpace(SearchTerm))
        {
            return tracks;
        }

        return tracks.Where(track =>
            (track.Name?.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (track.Artists?.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (track.Genre?.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (track.AlbumTitle?.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase) ?? false));
    }

    private static string DisplayName(MusicInfoModel track) => (track.Name ?? string.Empty).Replace(".mp3", string.Empty, StringComparison.OrdinalIgnoreCase);

    private void ClearSearch() => SearchTerm = string.Empty;
}
